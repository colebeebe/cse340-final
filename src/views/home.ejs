<%- include('partials/header') %>

<main class="home__page">
  <% if (user) { %>
    <h1>Welcome back to the Oasis, <%= user.first_name %>!</h1>
  <% } else { %>
    <h1>Welcome to the Oasis!</h1>
  <% } %>

  <div class="home-section new-review-section">
