  </div>
  
  <div class="home-section new-release-section">
    <h2>New Releases</h2>
    <div class="home-container new-release-container">
      <% newReleases.forEach((game) => { %>
        <a href="/games/<%= game.id %>" class="game-card new-release-card">
          <h3><%= game.title %></h3>
          <div class="img-container">
            <img src="<%= game.cover_image %>" alt="cover photo for <%= game.title %>" />
          </div>
          <p class="release-date">Released: <%= new Date(game.release_date).toLocaleDateString() %></p>
        </a>
      <% }); %>
    </div>
  </div>

  <div class="home-section latest-section">
    <h2>Recently Added</h2>
    <div class="home-container latest-container">
      <% recentlyAdded.forEach((game) => { %>
        <a href="/games/<%= game.id %>" class="game-card latest-card">
          <h3><%= game.title %></h3>
          <div class="img-container">
            <img src="<%= game.cover_image %>" alt="cover photo for <%= game.title %>" />
          </div>
          <p class="release-date">Released: <%= new Date(game.release_date).toLocaleDateString() %></p>
        </a>
      <% }); %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
